{
  "$comment": "CANONICAL ENDPOINT MANIFEST single source of truth for every Zatabox SDK. Hand-derived from the Zatabox REST API route definitions (the public OpenAPI spec is intentionally partial; the live routes are authoritative). Each SDK's resource layer is GENERATED from this file by scripts/generate.mjs, so the five languages never drift. Path params are written as :name and become positional method arguments in declaration order. kind defaults to 'json'; 'binary' returns raw bytes (PDF/CSV/XML), 'sse' generates a *Url() helper for streaming, 'multipart' is hand-implemented in each core.",
  "apiVersion": "1.0.0",
  "basePath": "/api/v1",
  "groups": [
    {
      "ns": "auth",
      "title": "Auth",
      "desc": "Registration, password + passwordless sign-in, token refresh, 2FA and verification.",
      "endpoints": [
        { "name": "register", "method": "POST", "path": "/api/v1/auth/register", "desc": "Register a new user with email + password." },
        { "name": "login", "method": "POST", "path": "/api/v1/auth/login", "desc": "Sign in with email + password; returns the JWT pair (or a 2FA challenge)." },
        { "name": "loginVerify2fa", "method": "POST", "path": "/api/v1/auth/2fa-verify", "desc": "Complete a login that returned a 2FA challenge." },
        { "name": "refresh", "method": "POST", "path": "/api/v1/auth/refresh", "desc": "Exchange a refresh token for a fresh access/refresh pair." },
        { "name": "logout", "method": "POST", "path": "/api/v1/auth/logout", "desc": "Revoke a refresh token." },
        { "name": "forgotPassword", "method": "POST", "path": "/api/v1/auth/forgot-password", "desc": "Email a password-reset link." },
        { "name": "resetPassword", "method": "POST", "path": "/api/v1/auth/reset-password", "desc": "Set a new password using a reset token." },
        { "name": "requestToken", "method": "POST", "path": "/api/v1/auth/token/request", "desc": "Passwordless: email a 6-digit login code." },
        { "name": "exchangeToken", "method": "POST", "path": "/api/v1/auth/token/exchange", "desc": "Passwordless: swap an emailed code for the JWT pair." },
        { "name": "verifyOtp", "method": "POST", "path": "/api/v1/auth/verify-otp", "desc": "Verify a one-time passcode." },
        { "name": "verifyEmail", "method": "POST", "path": "/api/v1/auth/verify-email", "desc": "Confirm an email address from a verification token." },
        { "name": "verifyPhone", "method": "POST", "path": "/api/v1/auth/verify-phone", "desc": "Confirm a phone number from an SMS code." },
        { "name": "loginOauth", "method": "POST", "path": "/api/v1/auth/login/oauth", "desc": "Sign in with a third-party OAuth identity token." },
        { "name": "enable2fa", "method": "POST", "path": "/api/v1/auth/2fa/enable", "desc": "Begin enrolling TOTP two-factor auth." },
        { "name": "verify2fa", "method": "POST", "path": "/api/v1/auth/2fa/verify", "desc": "Confirm a TOTP code to finish 2FA enrollment." }
      ]
    },
    {
      "ns": "users",
      "title": "Users (Buyer)",
      "desc": "The authenticated account: profile, wallet, tickets, orders, refunds, reports, messaging and notifications.",
      "endpoints": [
        { "name": "me", "method": "GET", "path": "/api/v1/users/me", "desc": "Current user profile." },
        { "name": "updateMe", "method": "PUT", "path": "/api/v1/users/me", "desc": "Update the current user profile." },
        { "name": "orders", "method": "GET", "path": "/api/v1/users/me/orders", "desc": "List the buyer's orders." },
        { "name": "tickets", "method": "GET", "path": "/api/v1/users/me/tickets", "desc": "List the buyer's tickets across all organizers." },
        { "name": "deleteAccount", "method": "DELETE", "path": "/api/v1/users/me", "desc": "Close the account." },
        { "name": "changePassword", "method": "POST", "path": "/api/v1/users/me/password", "desc": "Change the account password." },
        { "name": "activity", "method": "GET", "path": "/api/v1/users/me/activity", "desc": "Recent account activity." },
        { "name": "loginInfo", "method": "GET", "path": "/api/v1/users/me/login-info", "desc": "Last-login metadata." },
        { "name": "twofaStatus", "method": "GET", "path": "/api/v1/users/me/2fa/status", "desc": "Whether 2FA is enabled." },
        { "name": "twofaSetup", "method": "POST", "path": "/api/v1/users/me/2fa/setup", "desc": "Start 2FA setup (returns the TOTP secret/QR)." },
        { "name": "twofaEnable", "method": "POST", "path": "/api/v1/users/me/2fa/enable", "desc": "Enable 2FA after verifying a code." },
        { "name": "twofaDisable", "method": "POST", "path": "/api/v1/users/me/2fa/disable", "desc": "Disable 2FA." },
        { "name": "createRefund", "method": "POST", "path": "/api/v1/users/me/refunds", "desc": "Submit a refund request for a ticket." },
        { "name": "refunds", "method": "GET", "path": "/api/v1/users/me/refunds", "desc": "List the buyer's refund requests." },
        { "name": "withdrawRefund", "method": "POST", "path": "/api/v1/users/me/refunds/:id/withdraw", "desc": "Withdraw a pending refund request." },
        { "name": "createReport", "method": "POST", "path": "/api/v1/users/me/reports", "desc": "File a report against an event or organizer." },
        { "name": "reports", "method": "GET", "path": "/api/v1/users/me/reports", "desc": "List the buyer's filed reports." },
        { "name": "messages", "method": "GET", "path": "/api/v1/users/me/messages", "desc": "Message threads with organizers." },
        { "name": "messageThread", "method": "GET", "path": "/api/v1/users/me/messages/:threadId", "desc": "A single message thread." },
        { "name": "sendTicketMessage", "method": "POST", "path": "/api/v1/users/me/tickets/:ticketId/message", "desc": "Message the organizer of a ticket." },
        { "name": "notifications", "method": "GET", "path": "/api/v1/users/me/notifications", "desc": "In-app notifications." },
        { "name": "notificationsUnreadCount", "method": "GET", "path": "/api/v1/users/me/notifications/unread-count", "desc": "Count of unread notifications." },
        { "name": "markNotificationsRead", "method": "POST", "path": "/api/v1/users/me/notifications/read", "desc": "Mark notifications as read." },
        { "name": "updateAvatar", "method": "PUT", "path": "/api/v1/users/me/avatar", "desc": "Update the account avatar." },
        { "name": "updateNotificationSettings", "method": "PUT", "path": "/api/v1/users/me/notifications/settings", "desc": "Update notification preferences." }
      ]
    },
    {
      "ns": "savedSearches",
      "title": "Saved searches",
      "desc": "The buyer's saved discovery searches.",
      "endpoints": [
        { "name": "list", "method": "GET", "path": "/api/v1/users/me/saved-searches", "desc": "List saved searches." },
        { "name": "create", "method": "POST", "path": "/api/v1/users/me/saved-searches", "desc": "Save a search." },
        { "name": "delete", "method": "DELETE", "path": "/api/v1/users/me/saved-searches/:id", "desc": "Delete a saved search." }
      ]
    },
    {
      "ns": "dataExport",
      "title": "Data export",
      "desc": "GDPR-style export of the account's data.",
      "endpoints": [
        { "name": "get", "method": "GET", "path": "/api/v1/users/me/export", "desc": "Export all of the account's data." }
      ]
    },
    {
      "ns": "events",
      "title": "Events (Public)",
      "desc": "Public event discovery rails and per-event read panels.",
      "endpoints": [
        { "name": "list", "method": "GET", "path": "/api/v1/events", "desc": "List / search public events (cursor-paginated)." },
        { "name": "trending", "method": "GET", "path": "/api/v1/events/trending", "desc": "Trending events." },
        { "name": "categories", "method": "GET", "path": "/api/v1/events/categories", "desc": "Event categories with counts." },
        { "name": "nearby", "method": "GET", "path": "/api/v1/events/nearby", "desc": "Events near a lat/lng or city." },
        { "name": "newThisWeek", "method": "GET", "path": "/api/v1/events/new-this-week", "desc": "Recently published events." },
        { "name": "endingSoon", "method": "GET", "path": "/api/v1/events/ending-soon", "desc": "Events with sales ending soon." },
        { "name": "free", "method": "GET", "path": "/api/v1/events/free", "desc": "Free events." },
        { "name": "recommended", "method": "GET", "path": "/api/v1/events/recommended", "desc": "Personalized recommendations." },
        { "name": "schedule", "method": "GET", "path": "/api/v1/events/:id/schedule", "desc": "An event's session schedule." },
        { "name": "organizer", "method": "GET", "path": "/api/v1/events/:id/organizer", "desc": "Public organizer profile for an event." },
        { "name": "faq", "method": "GET", "path": "/api/v1/events/:id/faq", "desc": "An event's FAQ." },
        { "name": "related", "method": "GET", "path": "/api/v1/events/:id/related", "desc": "Related events." },
        { "name": "expressInterest", "method": "POST", "path": "/api/v1/events/:id/interest", "desc": "Register interest in an event." },
        { "name": "issue", "method": "POST", "path": "/api/v1/events/:eventId/issue", "desc": "Externally issue a ticket for an event (integrator mode)." },
        { "name": "get", "method": "GET", "path": "/api/v1/events/:slug", "desc": "Get a public event by slug." },
        { "name": "tickets", "method": "GET", "path": "/api/v1/events/:id/tickets", "desc": "List an event's purchasable ticket types." }
      ]
    },
    {
      "ns": "tickets",
      "title": "Tickets",
      "desc": "Ticket QR/PDF, peer-to-peer transfers, promo validation and wallet passes.",
      "endpoints": [
        { "name": "validatePromo", "method": "POST", "path": "/api/v1/tickets/promo/validate", "desc": "Validate a promo code against a cart." },
        { "name": "qr", "method": "GET", "path": "/api/v1/tickets/:id/qr", "desc": "Current rotating QR payload for a ticket (JSON)." },
        { "name": "pdf", "method": "GET", "path": "/api/v1/tickets/:id/pdf", "kind": "binary", "desc": "Ticket PDF (application/pdf bytes)." },
        { "name": "transfer", "method": "POST", "path": "/api/v1/tickets/:id/transfer", "desc": "Initiate a peer-to-peer transfer; the recipient gets a claim link." },
        { "name": "revokeTransfer", "method": "POST", "path": "/api/v1/tickets/transfers/:transferId/revoke", "desc": "Revoke a still-pending transfer (initiator only)." },
        { "name": "getTransfer", "method": "GET", "path": "/api/v1/tickets/transfers/claim/:token", "desc": "Inspect a pending transfer by claim token." },
        { "name": "claimTransfer", "method": "POST", "path": "/api/v1/tickets/transfers/claim/:token", "desc": "Claim a transfer; rewrites the ticket holder to the recipient." },
        { "name": "walletPass", "method": "GET", "path": "/api/v1/tickets/:id/wallet-pass", "desc": "Google/Apple wallet 'Save to Wallet' link (JSON)." },
        { "name": "listByEvent", "method": "GET", "path": "/api/v1/tickets/:eventId", "desc": "List ticket types for an event (legacy /ticket-types mount)." }
      ]
    },
    {
      "ns": "orders",
      "title": "Orders",
      "desc": "Carted checkout: create, pay, cancel, invoice.",
      "endpoints": [
        { "name": "create", "method": "POST", "path": "/api/v1/orders", "desc": "Create an order (reserves inventory)." },
        { "name": "get", "method": "GET", "path": "/api/v1/orders/:id", "desc": "Order detail." },
        { "name": "cancel", "method": "POST", "path": "/api/v1/orders/:id/cancel", "desc": "Cancel an order and release its hold." },
        { "name": "pay", "method": "POST", "path": "/api/v1/orders/:id/pay", "desc": "Initiate payment for an order (nowpayments | paystack | flutterwave)." },
        { "name": "invoice", "method": "GET", "path": "/api/v1/orders/:id/invoice", "kind": "binary", "desc": "Order receipt PDF (application/pdf bytes)." }
      ]
    },
    {
      "ns": "payments",
      "title": "Payments",
      "desc": "Payment intent creation, verification, method discovery, and inbound provider webhooks.",
      "endpoints": [
        { "name": "verify", "method": "POST", "path": "/api/v1/payments/verify", "desc": "Confirm a charge with the provider and complete the order (idempotent)." },
        { "name": "get", "method": "GET", "path": "/api/v1/payments/:orderId", "desc": "Payment status for an order." },
        { "name": "initiate", "method": "POST", "path": "/api/v1/payments/initiate", "desc": "Create a payment intent." },
        { "name": "methods", "method": "GET", "path": "/api/v1/payments/methods", "desc": "Available payment methods for a currency." },
        { "name": "cryptoCurrencies", "method": "GET", "path": "/api/v1/payments/crypto/currencies", "desc": "Supported crypto currencies (NOWPayments)." },
        { "name": "webhookNowpayments", "method": "POST", "path": "/api/v1/payments/webhook/nowpayments", "desc": "Inbound NOWPayments webhook (provider callback; not for client use)." },
        { "name": "webhookPaystack", "method": "POST", "path": "/api/v1/payments/webhook/paystack", "desc": "Inbound Paystack webhook (provider callback; not for client use)." },
        { "name": "webhookFlutterwave", "method": "POST", "path": "/api/v1/payments/webhook/flutterwave", "desc": "Inbound Flutterwave webhook (provider callback; not for client use)." }
      ]
    },
    {
      "ns": "checkin",
      "title": "Check-in",
      "desc": "Gate scanning, offline manifests, batch sync, live stats and CSV export.",
      "endpoints": [
        { "name": "scan", "method": "POST", "path": "/api/v1/checkin/scan", "desc": "Validate a QR / short-code ticket at a gate." },
        { "name": "batch", "method": "POST", "path": "/api/v1/checkin/batch", "desc": "Flush a queue of scans captured offline." },
        { "name": "manual", "method": "POST", "path": "/api/v1/checkin/event/:id/manual", "desc": "Manually check in an attendee." },
        { "name": "manifest", "method": "GET", "path": "/api/v1/checkin/event/:id/manifest", "desc": "Offline manifest (ticket hashes + statuses); pass ?since for a delta." },
        { "name": "stats", "method": "GET", "path": "/api/v1/checkin/event/:id/stats", "desc": "Live check-in stats snapshot." },
        { "name": "registerDevice", "method": "POST", "path": "/api/v1/checkin/device/register", "desc": "Register a scanning device." },
        { "name": "live", "method": "GET", "path": "/api/v1/checkin/event/:id/live", "kind": "sse", "desc": "Server-Sent Events stream of live check-in stats." },
        { "name": "gate", "method": "GET", "path": "/api/v1/checkin/event/:id/gate/:gate", "desc": "Per-gate check-in stats." },
        { "name": "export", "method": "GET", "path": "/api/v1/checkin/event/:id/export", "kind": "binary", "desc": "Check-in log CSV (text/csv bytes)." }
      ]
    },
    {
      "ns": "scan",
      "title": "Scanner-token check-in",
      "desc": "Passwordless gate scanning using a short-lived scanner token (the /scan kiosk surface).",
      "endpoints": [
        { "name": "exchange", "method": "POST", "path": "/api/v1/checkin-token/exchange", "desc": "Exchange a scanner token for a scoped session." },
        { "name": "session", "method": "GET", "path": "/api/v1/checkin-token/me", "desc": "Current scanner session (event + gate context)." },
        { "name": "scan", "method": "POST", "path": "/api/v1/checkin-token/scan", "desc": "Validate a ticket with the scanner session." },
        { "name": "manifest", "method": "GET", "path": "/api/v1/checkin-token/manifest", "desc": "Offline manifest for the scanner session." },
        { "name": "batch", "method": "POST", "path": "/api/v1/checkin-token/batch", "desc": "Flush offline scans for the scanner session." }
      ]
    },
    {
      "ns": "search",
      "title": "Search",
      "desc": "Full-text + faceted event search.",
      "endpoints": [
        { "name": "query", "method": "GET", "path": "/api/v1/search", "desc": "Full-text + faceted search." },
        { "name": "suggest", "method": "GET", "path": "/api/v1/search/suggest", "desc": "Type-ahead suggestions." },
        { "name": "trending", "method": "GET", "path": "/api/v1/search/trending", "desc": "Trending search terms." },
        { "name": "popular", "method": "GET", "path": "/api/v1/search/popular/:city", "desc": "Popular searches in a city." }
      ]
    },
    {
      "ns": "media",
      "title": "Media",
      "desc": "Image/asset uploads and the stable /media/:id resolver.",
      "endpoints": [
        { "name": "upload", "method": "POST", "path": "/api/v1/media/upload", "kind": "multipart", "desc": "Upload an image/asset (multipart/form-data)." }
      ]
    },
